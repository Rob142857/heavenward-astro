{
  "name": "heavenward",
  "version": "0.1.0",
  "description": "Dusk-till-dawn astronomical event report — everything visible tonight, one tap away",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "typecheck": "tsc --noEmit",
    "refresh": "node --experimental-strip-types scripts/refresh-catalog.ts --all"
  },
  "keywords": [
    "astronomy",
    "stargazing",
    "pwa",
    "cloudflare-workers",
    "ephemeris"
  ],
  "author": "Rob142857",
  "license": "Apache-2.0",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260509.1",
    "@hono/node-server": "^2.0.2",
    "@mlc-ai/web-llm": "^0.2.83",
    "astronomy-engine": "^2.1.19",
    "hono": "^4.12.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-precaching": "^7.4.1",
    "wrangler": "^4.90.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "sharp": "^0.34.5"
  }
}
